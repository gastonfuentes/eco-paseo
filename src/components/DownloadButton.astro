---
interface Props {
  href: string;
  label: string;
  filename?: string;
}

const { href, label, filename = "eco-paseo-san-francisco.pdf" } = Astro.props;
---

<a class="download-btn" href={href} download={filename}>
  <span class="download-btn__label">{label}</span>
  <svg
    class="download-btn__icon"
    width="16"
    height="16"
    viewBox="0 0 16 16"
    aria-hidden="true"
  >
    <path
      d="M8 1.5v9m0 0L4.5 7m3.5 3.5L11.5 7M2 13.5h12"
      stroke="currentColor"
      stroke-width="1.5"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</a>

<style>
  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: var(--radius-soft);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .download-btn:hover {
    background: var(--color-fg);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .download-btn:focus-visible {
    outline-offset: 4px;
  }

  .download-btn__icon {
    transition: transform 0.2s ease;
  }

  .download-btn:hover .download-btn__icon {
    transform: translateY(2px);
  }
</style>
