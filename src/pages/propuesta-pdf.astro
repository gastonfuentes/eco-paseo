---
import { getCollection, render } from "astro:content";
import Print from "../layouts/Print.astro";

const all = await getCollection("propuesta");
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const visible = sorted.filter((s) => !s.data.draft);

const cover = visible.find((s) => s.data.order === 1);
const sections = visible.filter((s) => s.data.order !== 1);

const renderedCover = cover ? await render(cover) : null;
const renderedSections = await Promise.all(
  sections.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);

const today = new Date().toLocaleDateString("es-AR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Print title="Eco Paseo San Francisco — Propuesta">
  <div class="print-page">
    {
      cover && renderedCover && (
        <section class="print-cover">
          <p class="eyebrow">{cover.data.eyebrow ?? "Propuesta de intervención urbana"}</p>
          <h1>{cover.data.title}</h1>
          <div class="cover-lead">
            <renderedCover.Content />
          </div>
          <p class="cover-meta">Municipalidad de La Rioja &nbsp;·&nbsp; {today}</p>
        </section>
      )
    }

    {
      renderedSections.map(({ data, Content }) => (
        <section class="print-section">
          <p class="eyebrow">
            {String(data.order).padStart(2, "0")} · {data.eyebrow ?? "Sección"}
          </p>
          <h1>{data.title}</h1>
          <Content />
        </section>
      ))
    }
  </div>
</Print>
